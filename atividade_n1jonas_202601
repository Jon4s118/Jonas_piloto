    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            text-align: center;
            background-color:#5C5D57;
            padding: 40px;
        }.container-social {
            display: flex;
            gap: 15px; /* Espaço entre os botões */
        }

        /* Estilo Geral de um Botão Social (usando tag <a>) */
         botao-social {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none; /* Remove sublinhado */
            padding: 12px 20px;
            border-radius: 50px; /* Botão arredondado nas pontas */
            color: white; /* Cor do texto e ícone */
            font-weight: bold;
            font-size: 16px;
            transition: transform 0.2s ease, box-shadow 0.2s ease; /* Animação suave */
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        /* Efeito de passar o mouse (Hover) */
        .botao-social:hover {
            transform: translateY(-3px); /* Levanta o botão */
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }

        /* Estilo para o ícone dentro do botão */
        .botao-social i {
            margin-right: 10px; /* Espaço entre ícone e texto */
            font-size: 20px; /* Ícone um pouco maior */
        }

        /* --- Cores Específicas de cada Rede (Oficiais) --- */
        
        .instagram { background-color: #E1306C; }
        .instagram:hover { background-color: #c02157; }

        .facebook { background-color: #1877F2; }
        .facebook:hover { background-color: #145dbf; }

        
    </style>
</head>
